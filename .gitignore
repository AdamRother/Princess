# ── Secrets (never commit) ────────────────────────────────────
.env
config/client_secrets.json
config/token.json
config/secrets.yaml

# ── Generated output (user-specific, not source) ─────────────
# output/raw/videos/ is intentionally tracked — committed cache travels
# with the repo so any machine can do an incremental run instead of full scrape.
output/raw/channels/
output/runs/
output/transcripts/
output/current_script.md

# ── Python ───────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Logs / temp ──────────────────────────────────────────────
*.log
*.tmp
