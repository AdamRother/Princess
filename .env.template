# ─────────────────────────────────────────────────────────────
# Sales YT Research — environment config
# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── YouTube ───────────────────────────────────────────────────
# YouTube Data API v3 key (free, 10k units/day)
# How to get: references/setup/01-youtube-api-key.md
YOUTUBE_API_KEY=

# ── Google Workspace ──────────────────────────────────────────
# Google Sheet ID for topic research output
# Leave blank to auto-create on first run
TARGET_SHEET_ID=

# Google Drive folder ID for generated scripts
# Leave blank to auto-create on first run
TARGET_DOCS_FOLDER_ID=

# Path to OAuth 2.0 client secrets JSON (from Google Cloud Console)
# How to get: references/setup/02-google-auth.md
CLIENT_SECRETS_PATH=config/client_secrets.json

# ── Client / channel ──────────────────────────────────────────
# The YouTube channel this pipeline is running for.
# Used for tier calibration and script voice matching.
# Format: https://www.youtube.com/@YourHandle
CLIENT_CHANNEL_URL=

# One-line description of the niche and channel owner.
# Used in title generation and script writing to stay on-voice.
# Example: "Female sales coach teaching high-ticket closers to hit $10k-$20k/month"
CLIENT_NICHE_DESCRIPTION=
